# Modal app base URL (get this after deploying modal_app.py)
MODAL_ENDPOINT_URL=https://your-username--medgemma-inference-fastapi-app.modal.run

# Upload directory
UPLOAD_DIR=./uploads

# Maximum file size in MB
MAX_FILE_SIZE_MB=100

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=.dcm,.png,.jpg,.jpeg,.nii,.nii.gz
