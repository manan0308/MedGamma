# Copy this file to backend/.env and fill in the values

# Modal app base URL (get this after deploying modal/modal_app.py)
MODAL_ENDPOINT_URL=https://your-username--medgemma-inference-fastapi-app.modal.run

# HuggingFace token (for accessing MedGemma)
HF_TOKEN=hf_your_token_here

# Upload directory
UPLOAD_DIR=./uploads

# Maximum file size in MB
MAX_FILE_SIZE_MB=100
